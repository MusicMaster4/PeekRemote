{
  "name": "peek-remote-desktop",
  "productName": "Peek Remote",
  "version": "1.0.0",
  "description": "Peek Remote — private remote screen access over Tailscale.",
  "author": {
    "name": "MusicMaster4"
  },
  "license": "SEE LICENSE IN ../LICENSE",
  "private": true,
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --publish never",
    "dist:win": "electron-builder --win --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "release": "electron-builder --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  }
}
