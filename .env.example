# Copy this file to .env and change the values before starting the app.

# Required: 6-digit numeric PIN.
# Avoid obvious sequences such as 123456, 000000, 111111, 654321, 121212, or 112233.
APP_PIN=CHANGE_ME

# Local server used by FastAPI and published by Tailscale Serve.
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# Optional: path to the Tailscale executable.
# Empty = autodetect C:\Program Files\Tailscale\tailscale.exe or the PATH.
TAILSCALE_PATH=

# Pairing QR: lifetime in seconds and automatic browser opening on the PC.
QR_TTL_SECONDS=1800
QR_OPEN_BROWSER=true

# Local audit log. This file is ignored by git.
AUDIT_LOG_FILE=audit.log

# Wrong PIN attempts per IP before blocking until the server restarts.
MAX_FAILED_LOGINS=5

# Screenshot performance. JPEG is much lighter than PNG for remote viewing.
# Raise quality if you prefer sharper text; lower it if the phone connection is slow.
SCREENSHOT_FORMAT=jpeg
SCREENSHOT_QUALITY=82
LIVE_SCREENSHOT_QUALITY=68
LIVE_MAX_WIDTH=1920
SCREENSHOT_CACHE_MS=120
POST_INPUT_CAPTURE_DELAY_MS=300

# Optional and disabled by default: public Cloudflare Quick Tunnel.
# Leave empty to keep the app private inside the tailnet.
CLOUDFLARED_PATH=
CLOUDFLARED_ARGS=--no-autoupdate
